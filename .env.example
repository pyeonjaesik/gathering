# SerpAPI key for image search
SERPAPI_KEY=your_serpapi_key_here

# OpenAI API key for image analysis
OPENAI_API_KEY=your_openai_api_key_here

# Pass3(Gemini) 동시성 제한 (429 완화용, 권장 1~3)
PASS3_GEMINI_CONCURRENCY=1
PASS3_GEMINI_MODEL=gemini-2.5-flash

# HACCP API (품목보고번호 조회)
HACCP_API_URL=https://apis.data.go.kr/B553748/CertImgListServiceV3/getCertImgListServiceV3
HACCP_API_KEY=your_haccp_api_key_here
